         data-ad-format=&#34;link&#34;&gt;&lt;/ins&gt;
    &lt;script&gt;
    (adsbygoogle = window.adsbygoogle || []).push({});
    &lt;/script&gt;
&lt;/div&gt;


&lt;h3 id=&#34;1-pygments-をインストールする:542e8e8756734f1d2f842478b74647ca&#34;&gt;1.&lt;code&gt;pygments&lt;/code&gt;をインストールする。&lt;/h3&gt;

&lt;pre&gt;&lt;code class=&#34;language-bash&#34;&gt;pip install pygments 
&lt;/code&gt;&lt;/pre&gt;

&lt;h3 id=&#34;2-以下のコマンドでcssを生成する:542e8e8756734f1d2f842478b74647ca&#34;&gt;2. 以下のコマンドでcssを生成する。&lt;/h3&gt;

&lt;pre&gt;&lt;code class=&#34;language-bash&#34;&gt;pygmentize -a .highlight -S monokai -f html &amp;gt; css/monokai.css
&lt;/code&gt;&lt;/pre&gt;

&lt;h3 id=&#34;3-gemfileにpygmentsを追加:542e8e8756734f1d2f842478b74647ca&#34;&gt;3. Gemfileにpygmentsを追加&lt;/h3&gt;

&lt;pre&gt;&lt;code&gt;gem &#39;pygments.rb&#39;
&lt;/code&gt;&lt;/pre&gt;

&lt;h3 id=&#34;4-config-ymlに-以下の記載を追加する:542e8e8756734f1d2f842478b74647ca&#34;&gt;4. _config.ymlに、以下の記載を追加する。&lt;/h3&gt;

&lt;pre&gt;&lt;code class=&#34;language-yaml&#34;&gt;highlighter: pygments
&lt;/code&gt;&lt;/pre&gt;

&lt;h3 id=&#34;5-デプロイする:542e8e8756734f1d2f842478b74647ca&#34;&gt;5. デプロイする。&lt;/h3&gt;

&lt;h2 id=&#34;こんなかんじになりました:542e8e8756734f1d2f842478b74647ca&#34;&gt;こんなかんじになりました&lt;/h2&gt;

&lt;pre&gt;&lt;code class=&#34;language-Ruby&#34;&gt;def hoge
  puts &amp;quot;test&amp;quot;
end
&lt;/code&gt;&lt;/pre&gt;

