      &lt;ul&gt;
        &lt;li&gt;&lt;a href=&#34;#読む時代&#34;&gt;読む時代&lt;/a&gt;&lt;/li&gt;
        &lt;li&gt;&lt;a href=&#34;#書く時代&#34;&gt;書く時代&lt;/a&gt;&lt;/li&gt;
        &lt;li&gt;&lt;a href=&#34;#話す時代&#34;&gt;話す時代&lt;/a&gt;&lt;/li&gt;
      &lt;/ul&gt;
    &lt;/li&gt;
    &lt;li&gt;&lt;a href=&#34;#学び続けるコツ&#34;&gt;学び続けるコツ&lt;/a&gt;
      &lt;ul&gt;
        &lt;li&gt;&lt;a href=&#34;#身の回りのものをプログラミングする&#34;&gt;身の回りのものをプログラミングする&lt;/a&gt;&lt;/li&gt;
