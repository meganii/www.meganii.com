  &lt;ul&gt;
    &lt;li&gt;&lt;a href=&#34;#前提&#34;&gt;前提&lt;/a&gt;&lt;/li&gt;
    &lt;li&gt;&lt;a href=&#34;#インストール方法&#34;&gt;インストール方法&lt;/a&gt;
      &lt;ul&gt;
        &lt;li&gt;&lt;a href=&#34;#1appleのサイトからcommand-line-toolsをダウンロードインストール&#34;&gt;1.Appleのサイトから&lt;code&gt;Command Line Tools&lt;/code&gt;をダウンロード&amp;amp;インストール&lt;/a&gt;&lt;/li&gt;
        &lt;li&gt;&lt;a href=&#34;#2念の為homebrewを再インストール&#34;&gt;2.（念の為）Homebrewを再インストール&lt;/a&gt;&lt;/li&gt;
      &lt;/ul&gt;
    &lt;/li&gt;
    &lt;li&gt;&lt;a href=&#34;#確認&#34;&gt;確認&lt;/a&gt;&lt;/li&gt;
  &lt;/ul&gt;
