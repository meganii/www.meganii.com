  <span class="n">blog</span><span class="o">.</span><span class="n">tag_template</span> <span class="o">=</span> <span class="n">blog</span><span class="o">.</span><span class="n">prefix</span> <span class="o">+</span> <span class="s2">&quot;/tag.html&quot;</span>
