&lt;amp-img class="contain"
src="https://res.cloudinary.com/meganii/image/upload/v1585385651/blog-mentoring_j15qwo.png"
srcset="https://res.cloudinary.com/meganii/image/upload/q_auto,f_auto,w_1024/blog-mentoring_j15qwo.png 1024w,
https://res.cloudinary.com/meganii/image/upload/q_auto,f_auto,w_864/blog-mentoring_j15qwo.png 864w,
